<?xml version="1.0" encoding="utf-8"?>
<!--
  DiarioSync — fragment_historial.xml
  Pantalla: Historial de cajas cerradas
  Estructura:
    1. Header "Historial"
    2. RecyclerView de jornadas
    3. Gradiente inferior (fade)
    4. Footer con ImageButtons + FAB central (mismo estilo que fragment_lista)
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ds_bg">

    <!-- ── HEADER ─────────────────────────────── -->
    <LinearLayout
        android:id="@+id/headerBar"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:background="@color/ds_surface"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Historial"
            android:textColor="@color/ds_text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:letterSpacing="-0.01" />

        <TextView
            android:id="@+id/txtCantJornadas"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="0 cajas"
            android:textColor="@color/ds_text_tertiary"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:background="@drawable/bg_chip_neutral" />

    </LinearLayout>

    <!-- ── DIVIDER ─────────────────────────────── -->
    <View
        android:id="@+id/divHeader"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/ds_border"
        app:layout_constraintTop_toBottomOf="@id/headerBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── LISTA ───────────────────────────────── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingTop="8dp"
        android:paddingBottom="100dp"
        android:paddingHorizontal="12dp"
        app:layout_constraintTop_toBottomOf="@id/divHeader"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── GRADIENTE FADE INFERIOR ───────────────── -->
    <View
        android:id="@+id/gradientBottom"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:background="@drawable/gradient_list_bottom"
        app:layout_constraintBottom_toTopOf="@id/footerBg"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── FOOTER BG (igual que fragment_lista) ──── -->
    <View
        android:id="@+id/footerBg"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:background="@color/ds_surface"
        android:elevation="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── BOTÓN EXPORTAR (izquierda) ────────────── -->
    <ImageButton
        android:id="@+id/btnExportarHistorial"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="18dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_share"
        app:tint="@color/ds_text_secondary"
        android:elevation="5dp"
        android:contentDescription="Exportar historial"
        app:layout_constraintBottom_toBottomOf="@id/footerBg"
        app:layout_constraintStart_toStartOf="@id/footerBg"
        app:layout_constraintTop_toTopOf="@id/footerBg" />

    <!-- ── BOTÓN VACIAR (derecha) ─────────────────── -->
    <ImageButton
        android:id="@+id/btnVaciarTodo"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="24dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_delete"
        app:tint="@color/ds_red"
        android:elevation="5dp"
        android:contentDescription="Vaciar historial"
        app:layout_constraintBottom_toBottomOf="@id/footerBg"
        app:layout_constraintEnd_toEndOf="@id/footerBg"
        app:layout_constraintTop_toTopOf="@id/footerBg" />

</androidx.constraintlayout.widget.ConstraintLayout>