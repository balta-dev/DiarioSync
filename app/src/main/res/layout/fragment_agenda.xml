<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nestedScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ds_bg"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/containerPrincipal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingHorizontal="28dp"
        android:paddingTop="56dp"
        android:paddingBottom="40dp">

        <TextView
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:gravity="center"
            android:background="@mipmap/ic_launcher" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="DiarioSync"
            android:textColor="@color/ds_text_primary"
            android:textSize="26sp"
            android:textStyle="bold"
            android:letterSpacing="-0.02" />

        <TextView
            android:id="@+id/tvSubtitulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Ingresá a una agenda compartida"
            android:textColor="@color/ds_text_tertiary"
            android:textSize="14sp"
            android:gravity="center" />

        <!--
            ConstraintLayout con clipChildren=false para que las cards
            puedan cruzarse visualmente durante la animación sin recortarse.
            Las tres vistas se posicionan en cascada (cada una debajo de la anterior)
            y el código mueve TODO con translationY.
        -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layoutCards"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- CARD CREAR: posición base = arriba -->
            <LinearLayout
                android:id="@+id/cardCrear"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:background="@drawable/bg_card_surface2"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NUEVA AGENDA"
                    android:textColor="@color/ds_green"
                    android:textSize="10sp"
                    android:letterSpacing="0.1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="16dp"
                    android:text="Elegí un código único. Compartíselo a quien quieras que se una contigo."
                    android:textColor="@color/ds_text_secondary"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.3" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilCodigoCrear"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.DS.TextInputLayout"
                    android:hint="Código (ej: ALMACEN23)">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilPasswordCrear"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        style="@style/Widget.DS.TextInputLayout"
                        android:hint="Contraseña (Opcional)"
                        app:endIconMode="password_toggle">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPasswordCrear"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword"
                            android:imeOptions="actionDone"
                            android:textColor="@color/ds_text_primary"
                            android:textSize="15sp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etCodigoCrear"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapCharacters"
                        android:imeOptions="actionDone"
                        android:maxLength="18"
                        android:textColor="@color/ds_text_primary"
                        android:textSize="15sp"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.05" />

                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCrearAgenda"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="14dp"
                    android:text="CREAR Y ENTRAR"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/ds_green"
                    app:cornerRadius="10dp" />

            </LinearLayout>

            <!-- SEPARADOR: posición base = entre cardCrear y cardUnirse -->
            <LinearLayout
                android:id="@+id/layoutSeparador"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="24dp"
                app:layout_constraintTop_toBottomOf="@id/cardCrear"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/ds_border2" />

                <TextView
                    android:id="@+id/tvSeparador"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="14dp"
                    android:text="o sumate a alguien más"
                    android:textColor="@color/ds_text_tertiary"
                    android:textSize="13sp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/ds_border2" />

            </LinearLayout>

            <!-- CARD UNIRSE: posición base = abajo -->
            <LinearLayout
                android:id="@+id/cardUnirse"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:background="@drawable/bg_card_surface2"
                app:layout_constraintTop_toBottomOf="@id/layoutSeparador"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="UNIRSE A AGENDA"
                    android:textColor="@color/ds_accent"
                    android:textSize="10sp"
                    android:letterSpacing="0.1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="16dp"
                    android:text="Ingresá el código que te compartieron para acceder a una agenda existente."
                    android:textColor="@color/ds_text_secondary"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.3" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilCodigoUnirse"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.DS.TextInputLayout"
                    android:hint="Código de la agenda">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etCodigoUnirse"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapCharacters"
                        android:imeOptions="actionDone"
                        android:maxLength="20"
                        android:textColor="@color/ds_text_primary"
                        android:textSize="15sp"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.05" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilPasswordUnirse"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        style="@style/Widget.DS.TextInputLayout"
                        android:hint="Contraseña (Opcional)"
                        app:endIconMode="password_toggle">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPasswordUnirse"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword"
                            android:imeOptions="actionDone"
                            android:textColor="@color/ds_text_primary"
                            android:textSize="15sp" />

                    </com.google.android.material.textfield.TextInputLayout>

                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnUnirseAgenda"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="14dp"
                    android:text="UNIRSE"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:cornerRadius="10dp" />

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:visibility="gone"
            android:indeterminateTint="@color/ds_accent" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>