<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ds_bg">

    <!-- ── HEADER ─────────────────────────────── -->
    <LinearLayout
        android:id="@+id/headerBar"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="12dp"
        android:background="@color/ds_surface"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/logoMark"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_logo_diariosync"
            android:contentDescription="DiarioSync" />

        <TextView
            android:id="@+id/txtAppName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="DiarioSync"
            android:textColor="@color/ds_text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:letterSpacing="-0.02" />

        <!-- Exportar (movido al header, izquierda del historial) -->
        <ImageButton
            android:id="@+id/btnExportar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="-4dp"
            android:background="@drawable/bg_icon_btn"
            android:src="@drawable/ic_share"
            app:tint="@color/ds_text_secondary"
            android:contentDescription="Exportar Excel" />

        <ImageButton
            android:id="@+id/btnHistorial"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/bg_icon_btn"
            android:src="@drawable/ic_history"
            app:tint="@color/ds_text_secondary"
            android:contentDescription="Historial" />

        <ImageButton
            android:id="@+id/btnFiltrar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_icon_btn"
            android:src="@drawable/ic_sort"
            app:tint="@color/ds_text_secondary"
            android:contentDescription="Filtrar" />

        <ImageButton
            android:id="@+id/btnPreferencias"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="0dp"
            android:background="@drawable/bg_icon_btn"
            android:src="@drawable/ic_settings"
            app:tint="@color/ds_text_secondary"
            android:contentDescription="Preferencias" />

    </LinearLayout>

    <!-- ── SUMMARY STRIP ──────────────────────── -->
    <LinearLayout
        android:id="@+id/summaryStrip"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:background="@color/ds_surface2"
        app:layout_constraintTop_toBottomOf="@id/headerBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingStart="0dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.08"
                android:text="INGRESOS"
                android:textColor="@color/ds_text_secondary"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/txtTotalVentas"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:fontFamily="monospace"
                android:text="$0,00"
                android:textColor="@color/ds_green"
                android:textStyle="bold"
                android:gravity="center"
                app:autoSizeTextType="uniform"
                app:autoSizeMinTextSize="4sp"
                app:autoSizeMaxTextSize="24sp"
                app:autoSizeStepGranularity="1sp" />
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="36dp"
            android:layout_gravity="center_vertical"
            android:background="@color/ds_border2" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingEnd="0dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EGRESOS"
                android:textColor="@color/ds_text_secondary"
                android:textSize="10sp"
                android:letterSpacing="0.08" />

            <TextView
                android:id="@+id/txtTotalCompras"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:fontFamily="monospace"
                android:text="$0,00"
                android:textColor="@color/ds_red"
                android:textStyle="bold"
                android:gravity="center"
                app:autoSizeTextType="uniform"
                app:autoSizeMinTextSize="4sp"
                app:autoSizeMaxTextSize="24sp"
                app:autoSizeStepGranularity="1sp" />
        </LinearLayout>

    </LinearLayout>

    <!-- ── LISTA ──────────────────────────────── -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/summaryStrip"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingTop="10dp"
            android:paddingBottom="140dp"
            android:paddingHorizontal="12dp" />

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- Gradiente top -->
    <View
        android:id="@+id/gradientTop"
        android:layout_width="0dp"
        android:layout_height="12dp"
        android:background="@drawable/gradient_list_top"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/summaryStrip" />

    <!-- Gradiente bottom -->
    <View
        android:id="@+id/gradientBottom"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:background="@drawable/gradient_list_bottom"
        app:layout_constraintBottom_toTopOf="@id/footerBg"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── FOOTER BG ───────────────────────────── -->
    <View
        android:id="@+id/footerBg"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:background="@color/ds_surface"
        android:elevation="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Código de sala + botón salir (izquierda del footer) -->
    <LinearLayout
        android:id="@+id/salaInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:elevation="5dp"
        app:layout_constraintBottom_toBottomOf="@id/footerBg"
        app:layout_constraintStart_toStartOf="@id/footerBg"
        app:layout_constraintTop_toTopOf="@id/footerBg">

        <!-- Botón salir de sala -->
        <ImageButton
            android:id="@+id/btnSalirSala"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_marginTop="1dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_close"
            app:tint="@color/ds_red"
            android:contentDescription="Salir de sala" />

        <!-- Código de la sala -->
        <TextView
            android:id="@+id/txtCodigoSala"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="10dp"
            android:paddingVertical="5dp"

            android:text="SALA"
            android:textColor="@color/ds_accent"
            android:textSize="12sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:background="@drawable/bg_chip_neutral"
            android:letterSpacing="0.05" />

    </LinearLayout>

    <!-- Cerrar caja (derecha del footer) -->
    <LinearLayout
        android:id="@+id/btnCerrarCaja"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_marginEnd="20dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="14dp"
        android:paddingVertical="0dp"
        android:background="@drawable/bg_cerrar_caja"
        android:elevation="6dp"
        android:translationZ="6dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintBottom_toBottomOf="@id/footerBg"
        app:layout_constraintEnd_toEndOf="@id/footerBg"
        app:layout_constraintTop_toTopOf="@id/footerBg">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cerrar caja"
            android:includeFontPadding="false"
            android:textColor="@color/ds_text_tertiary"
            android:textSize="13sp"
            android:layout_marginEnd="8dp"/>

        <ImageView
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:src="@drawable/ic_receipt"
            app:tint="@color/ds_text_secondary" />

    </LinearLayout>

    <!-- FAB agregar — esquina inferior derecha, flota sobre el footer -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/btnNuevaOperacion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="76dp"
        android:text="Agregar"
        android:textColor="@color/white"
        android:textAllCaps="false"
        android:elevation="12dp"
        app:icon="@drawable/ic_add"
        app:iconTint="@color/white"
        app:rippleColor="@color/ds_accent"
        android:backgroundTint="@color/ds_accent_border"
        app:cornerRadius="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>