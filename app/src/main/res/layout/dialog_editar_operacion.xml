<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/ds_surface">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="GESTIÓN"
        android:textColor="@color/ds_accent"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.2" />

    <TextView
        android:id="@+id/tvTituloEditar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Opciones de operación"
        android:textColor="@color/ds_text_primary"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tvCuerpoEditar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="¿Deseas modificar los datos de esta entrada?"
        android:textColor="@color/ds_text_secondary"
        android:textSize="14sp"
        android:layout_marginBottom="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_stat_card"
        android:padding="12dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvRefProducto"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/ds_text_primary"
            android:textStyle="bold"
            android:textSize="14sp"
            android:text="Producto" />

        <TextView
            android:id="@+id/tvRefMonto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/ds_accent"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:text="$0.00" />
    </LinearLayout>

</LinearLayout>