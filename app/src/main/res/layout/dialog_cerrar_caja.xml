<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/ds_surface">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CONFIRMACIÓN"
        android:textColor="@color/ds_accent"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.2" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="¿Cerrar la jornada?"
        android:textColor="@color/ds_text_primary"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Se generará el archivo Excel y se limpiará la lista actual."
        android:textColor="@color/ds_text_secondary"
        android:textSize="14sp"
        android:layout_marginBottom="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_stat_card"
        android:padding="14dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvCantOperaciones"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/ds_text_tertiary"
            android:textSize="11sp"
            android:text="14 OPERACIONES"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvResumenVentas"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/ds_green"
            android:fontFamily="monospace"
            android:textSize="15sp"
            android:textStyle="bold"
            android:text="Ventas:  $0,00" />

        <TextView
            android:id="@+id/tvResumenCompras"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/ds_red"
            android:fontFamily="monospace"
            android:textSize="15sp"
            android:textStyle="bold"
            android:text="Compras: $0,00" />

    </LinearLayout>

</LinearLayout>