<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/ds_surface">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ZONA DE PELIGRO"
        android:textColor="@color/ds_red"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.2"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tvTituloSalir"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="¿Salir de la sala?"
        android:textColor="@color/ds_text_primary"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/tvCuerpoSalir"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Vas a desconectarte de la agenda. Los datos locales se borrarán. Si no quedan otros miembros, la sala desaparecerá de la nube."
        android:textColor="@color/ds_text_secondary"
        android:textSize="14sp"
        android:lineSpacingExtra="4dp" />

</LinearLayout>